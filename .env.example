# =============================================================================
# miuOps Stack Environment Variables
# Fill these into /opt/stacks/.env on the server (see README → Quick Start).
# =============================================================================
#
# NAMING CONVENTION — every variable is namespaced; there are NO bare/generic
# names. All stacks on a server share THIS one file, so an unprefixed name (e.g.
# DB_PASSWORD) used by two projects would silently override the other.
#
#   - Project vars: prefix with the project handle (e.g. MYAPP_DB_PASSWORD),
#     then map to the app's expected name in compose:
#         environment:
#           DB_PASSWORD: ${MYAPP_DB_PASSWORD}   # left = app name, right = .env name
#   - Shared infrastructure: the backup S3 account (used by the offen volume
#     backup AND WAL-G) uses the BACKUP_ namespace below.

# -- Shared backup S3 account (offen volume backup + WAL-G) -------------------
# Run scripts/setup-s3-backup.sh in the metal repo to create these.
BACKUP_AWS_ACCESS_KEY_ID=AKIAEXAMPLE
BACKUP_AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
BACKUP_AWS_REGION=us-west-2

# -- Offen volume backup ------------------------------------------------------
BACKUP_S3_BUCKET=myproject-backup
# Optional: S3-compatible endpoint (leave empty for AWS S3)
BACKUP_AWS_ENDPOINT=
# Optional: S3 prefix path (default: vol)
BACKUP_S3_PATH=vol

# -- Backup encryption (strongly recommended, pick ONE method) ----------------
# Backups include .env (secrets) — encrypt to protect them at rest.
# See https://github.com/tianshanghong/miuops/blob/main/docs/BACKUP_ENCRYPTION.md
# BACKUP_GPG_PASSPHRASE=
# BACKUP_AGE_PASSPHRASE=
# BACKUP_AGE_PUBLIC_KEYS=
# GPG asymmetric uses a key file, not an env var — see the link above.

# -- WAL-G (PostgreSQL continuous archiving) — one prefix PER database app -----
# Prefix the var with the app handle (each DB app gets its own S3 prefix).
# Format: s3://<bucket>/db/<app-name>
MYAPP_WALG_S3_PREFIX=s3://myproject-backup/db/myapp

# -- Per-project app variables (prefix EVERY var with the project handle) ------
# Example for an app whose handle is "myapp"; reference them in that stack's
# compose as e.g.  DB_PASSWORD: ${MYAPP_DB_PASSWORD}
# MYAPP_DB_PASSWORD=
# MYAPP_API_KEY=

# -- Docker registry authentication (optional) --------------------------------
# Pull images from private registries. Name each registry however you like.
# Pattern: DOCKER_REGISTRY_<NAME>_URL, _USER, _PASSWORD
# The deploy workflow auto-discovers and logs in to all configured registries.

# GitHub Container Registry
# Create a Personal Access Token with read:packages scope:
# https://github.com/settings/tokens
# DOCKER_REGISTRY_GHCR_URL=ghcr.io
# DOCKER_REGISTRY_GHCR_USER=your-github-username
# DOCKER_REGISTRY_GHCR_PASSWORD=ghp_xxxxxxxxxxxx

# Docker Hub
# Create an access token: https://hub.docker.com/settings/security
# DOCKER_REGISTRY_DOCKERHUB_URL=docker.io
# DOCKER_REGISTRY_DOCKERHUB_USER=your-dockerhub-username
# DOCKER_REGISTRY_DOCKERHUB_PASSWORD=dckr_pat_xxxxxxxxxxxx

# Custom registry (any OCI-compatible registry)
# DOCKER_REGISTRY_WORK_URL=registry.example.com
# DOCKER_REGISTRY_WORK_USER=your-username
# DOCKER_REGISTRY_WORK_PASSWORD=your-token
